# Runtime theme state generated by theme-engine/theme-set.sh
current/

# DMS auto-generates these into ~/.config/niri/dms/ at runtime (each one is
# stamped "DO NOT EDIT - AUTO-GENERATED BY DMS") - some are machine-specific
# (outputs.kdl has hardcoded resolution/output names), so don't track them.
# dms/binds.kdl is the one exception: it's DMS/user-editable, not purely
# auto-generated, and we ship a starter set - so it stays tracked.
config/niri/dms/colors.kdl
config/niri/dms/layout.kdl
config/niri/dms/alttab.kdl
config/niri/dms/outputs.kdl
config/niri/dms/cursor.kdl
config/niri/dms/windowrules.kdl
config/niri/dms/wpblur.kdl
