[Plymouth Theme]
Name=Omarchy Look
Description=Minimal tokyo-night boot splash, no branding.
ModuleName=script

[script]
ImageDir=/usr/share/plymouth/themes/omarchy-look
ScriptFile=/usr/share/plymouth/themes/omarchy-look/omarchy-look.script
ConsoleLogBackgroundColor=0x1a1b26
MonospaceFont=JetBrainsMono Nerd Font 11
Font=JetBrainsMono Nerd Font 11
