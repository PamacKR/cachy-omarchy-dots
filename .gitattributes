# These run as bash scripts on Linux — must stay LF, never CRLF.
*.sh text eol=lf
bin/* text eol=lf
theme-engine/theme-set.sh text eol=lf

# Config formats that are also parsed on Linux; keep them LF too.
*.toml text eol=lf
*.ini text eol=lf
*.conf text eol=lf
*.kdl text eol=lf
*.css text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.desktop text eol=lf
*.script text eol=lf
*.plymouth text eol=lf
*.service text eol=lf
mimeapps.list text eol=lf

# Binary assets — don't touch at all.
*.png binary
*.jpg binary
