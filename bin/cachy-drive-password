#!/usr/bin/env bash
# Change the encryption password on a LUKS-encrypted drive.
set -euo pipefail

encrypted_drives=$(blkid -t TYPE=crypto_LUKS -o device || true)

if [[ -z $encrypted_drives ]]; then
  echo "No encrypted drives available." >&2
  exit 1
fi

if (($(wc -l <<<"$encrypted_drives") == 1)); then
  drive_to_change="$encrypted_drives"
else
  drive_to_change="$(cachy-drive-select "$encrypted_drives")"
fi

if [[ -n $drive_to_change ]]; then
  echo "Changing full-disk encryption password for $drive_to_change"
  sudo cryptsetup luksChangeKey --pbkdf argon2id --iter-time 2000 "$drive_to_change"
else
  echo "No drive selected."
fi
