#!/usr/bin/env bash
# Called by swayidle on timeout. Suspends only if currently running on
# battery power; a no-op while plugged in (AC power never auto-sleeps).
set -euo pipefail

on_ac=0
for supply in /sys/class/power_supply/A{C,DP}*; do
  [[ -f "$supply/online" ]] || continue
  [[ "$(cat "$supply/online")" == "1" ]] && on_ac=1
done

[[ $on_ac -eq 1 ]] && exit 0

systemctl suspend
