#!/usr/bin/env bash
# Launch a TUI command in a floating Alacritty scratch terminal.
# Usage: launch-tui <command> [args...]
set -euo pipefail

[[ $# -ge 1 ]] || { echo "Usage: launch-tui <command> [args...]" >&2; exit 1; }

exec setsid alacritty --class "cachy-dots-scratch-term,cachy-dots-scratch-term" -e "$@"
