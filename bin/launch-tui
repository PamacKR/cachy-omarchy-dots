#!/usr/bin/env bash
# Launch a TUI command in an Alacritty scratch terminal, tagged with a given
# app-id/class so niri's window-rules can decide floating vs tiled per caller
# (the text-editor scratch term tiles; cachy-menu's utility terminals float).
# Usage: launch-tui <app-id> <command> [args...]
set -euo pipefail

[[ $# -ge 2 ]] || { echo "Usage: launch-tui <app-id> <command> [args...]" >&2; exit 1; }

app_id="$1"
shift

exec setsid alacritty --class "$app_id,$app_id" -e "$@"
