#!/usr/bin/env bash
# Get/set the default terminal used by xdg-terminal-exec.
# Usage: cachy-default-terminal [alacritty|foot|ghostty|kitty]
set -euo pipefail

if (($# == 0)); then
  desktop_id=$(grep -vE '^($|#)' ~/.config/xdg-terminals.list 2>/dev/null | head -n1)
  case "$desktop_id" in
  Alacritty.desktop) echo "alacritty" ;;
  foot.desktop) echo "foot" ;;
  com.mitchellh.ghostty.desktop) echo "ghostty" ;;
  kitty.desktop) echo "kitty" ;;
  *) echo "$desktop_id" ;;
  esac
  exit 0
fi

case "$1" in
alacritty) desktop_id="Alacritty.desktop"; name="Alacritty" ;;
foot) desktop_id="foot.desktop"; name="Foot" ;;
ghostty) desktop_id="com.mitchellh.ghostty.desktop"; name="Ghostty" ;;
kitty) desktop_id="kitty.desktop"; name="Kitty" ;;
*)
  echo "Usage: cachy-default-terminal <alacritty|foot|ghostty|kitty>" >&2
  exit 1
  ;;
esac

cat >~/.config/xdg-terminals.list <<EOF
# Terminal emulator preference order for xdg-terminal-exec
$desktop_id
EOF

notify-send -u low "$name is now the default terminal"
