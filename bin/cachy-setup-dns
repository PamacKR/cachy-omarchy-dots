#!/usr/bin/env bash
# Configure the system DNS provider via systemd-resolved.
# Usage: cachy-setup-dns [Cloudflare|Google|DHCP|Custom]
set -euo pipefail

lock_dns_to_resolved() {
  for file in /etc/systemd/network/*.network; do
    [[ -f $file ]] || continue
    sed -n '/^\[DHCPv4\]/,/^\[/p' "$file" | grep -q "^UseDNS=" ||
      sudo sed -i '/^\[DHCPv4\]/a UseDNS=no' "$file"
    if grep -q "^\[IPv6AcceptRA\]" "$file" && ! sed -n '/^\[IPv6AcceptRA\]/,/^\[/p' "$file" | grep -q "^UseDNS="; then
      sudo sed -i '/^\[IPv6AcceptRA\]/a UseDNS=no' "$file"
    fi
  done
}

unlock_dns_to_dhcp() {
  for file in /etc/systemd/network/*.network; do
    [[ -f $file ]] || continue
    sudo sed -i '/^\[DHCPv4\]/{n;/^UseDNS=no$/d}' "$file"
    sudo sed -i '/^\[IPv6AcceptRA\]/{n;/^UseDNS=no$/d}' "$file"
  done
}

dns="${1:-$(gum choose --height 6 --header "Select DNS provider" Cloudflare Google DHCP Custom)}"

case "$dns" in
Cloudflare)
  sudo tee /etc/systemd/resolved.conf >/dev/null <<'EOF'
[Resolve]
DNS=1.1.1.1#cloudflare-dns.com 1.0.0.1#cloudflare-dns.com 2606:4700:4700::1111#cloudflare-dns.com 2606:4700:4700::1001#cloudflare-dns.com
FallbackDNS=9.9.9.9#dns.quad9.net 149.112.112.112#dns.quad9.net 2620:fe::fe#dns.quad9.net 2620:fe::9#dns.quad9.net
DNSOverTLS=opportunistic
EOF
  lock_dns_to_resolved
  ;;
Google)
  sudo tee /etc/systemd/resolved.conf >/dev/null <<'EOF'
[Resolve]
DNS=8.8.8.8#dns.google 8.8.4.4#dns.google 2001:4860:4860::8888#dns.google 2001:4860:4860::8844#dns.google
FallbackDNS=9.9.9.9#dns.quad9.net 149.112.112.112#dns.quad9.net 2620:fe::fe#dns.quad9.net 2620:fe::9#dns.quad9.net
DNSOverTLS=opportunistic
EOF
  lock_dns_to_resolved
  ;;
DHCP)
  sudo tee /etc/systemd/resolved.conf >/dev/null <<'EOF'
[Resolve]
DNSOverTLS=no
EOF
  unlock_dns_to_dhcp
  ;;
Custom)
  read -rp "Enter DNS servers (space-separated): " dns_servers
  [[ -n $dns_servers ]] || { echo "Error: no DNS servers provided." >&2; exit 1; }
  sudo tee /etc/systemd/resolved.conf >/dev/null <<EOF
[Resolve]
DNS=$dns_servers
FallbackDNS=9.9.9.9#dns.quad9.net 149.112.112.112#dns.quad9.net 2620:fe::fe#dns.quad9.net 2620:fe::9#dns.quad9.net
EOF
  lock_dns_to_resolved
  ;;
esac

sudo systemctl restart systemd-networkd systemd-resolved
