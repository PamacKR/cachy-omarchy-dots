#!/usr/bin/env bash
# Prompt for sudo once and keep the credential alive in the background for
# the lifetime of the calling script. Source this, don't exec it:
#   source cachy-sudo-keepalive
sudo -v
while true; do sudo -n true; sleep 60; done 2>/dev/null &
SUDO_KEEPALIVE_PID=$!
trap "kill $SUDO_KEEPALIVE_PID 2>/dev/null" EXIT
